<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eduswap.biz.mapper.BizCollectionMapper">
    
    <resultMap type="BizCollection" id="BizCollectionResult">
        <result property="collectId"    column="collect_id"    />
        <result property="userId"    column="user_id"    />
        <result property="productId"    column="product_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectBizCollectionVo">
        select collect_id, user_id, product_id, create_time, del_flag from biz_collection
    </sql>

    <select id="selectBizCollectionList" parameterType="BizCollection" resultMap="BizCollectionResult">
        <include refid="selectBizCollectionVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="productId != null "> and product_id = #{productId}</if>
        </where>
    </select>
    
    <select id="selectBizCollectionByCollectId" parameterType="Long" resultMap="BizCollectionResult">
        <include refid="selectBizCollectionVo"/>
        where collect_id = #{collectId}
    </select>

    <insert id="insertBizCollection" parameterType="BizCollection" useGeneratedKeys="true" keyProperty="collectId">
        insert into biz_collection
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="createTime != null">create_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateBizCollection" parameterType="BizCollection">
        update biz_collection
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </trim>
        where collect_id = #{collectId}
    </update>

    <delete id="deleteBizCollectionByCollectId" parameterType="Long">
        delete from biz_collection where collect_id = #{collectId}
    </delete>

    <delete id="deleteBizCollectionByCollectIds" parameterType="String">
        delete from biz_collection where collect_id in 
        <foreach item="collectId" collection="array" open="(" separator="," close=")">
            #{collectId}
        </foreach>
    </delete>
</mapper>